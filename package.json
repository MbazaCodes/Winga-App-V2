{
  "name":"winga-platform",
  "private":true,

  "workspaces":[
    "apps/*",
    "packages/*"
  ],

  "scripts":{

    "dev:web":"npm --workspace apps/web run dev",

    "dev:admin":"npm --workspace apps/admin run dev",

    "build":"npm run build --workspaces",

    "lint":"npm run lint --workspaces"

  }

}
