# ──────────────────────────────────────────────────────────────
# Winga Admin — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy to .env.local for local dev, or .env.production for prod

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# (Optional) Admin service role — for privileged operations
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Winga Admin